# Copy this file to .env and fill in your values:
#   copy .env.example .env

# --- LLM provider (we will use this in Phase 5) ---
# Choose one: gemini | openai
LLM_PROVIDER=gemini

# Google Gemini (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI (optional alternative)
# OPENAI_API_KEY=your_openai_api_key_here

# --- Embedding model (Phase 3) ---
# Small, fast model — good for learning and local dev
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Paths (defaults work out of the box) ---
PDF_DIR=documents
FAISS_INDEX_DIR=storage/faiss_index

# --- Chunking (Phase 2) ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- Retrieval (Phase 4) ---
TOP_K=4

# --- Level 2: confidence threshold (Phase 8) ---
# MIN_RETRIEVAL_SCORE=0.35
